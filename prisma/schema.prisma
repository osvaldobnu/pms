generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // ⚠️ Se estiver no Prisma 6 (recomendado agora)
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  ENVIADO
  EM_PREPARO
  PRONTO
}

enum PaymentMethod {
  DINHEIRO
  CARTAO
  PIX
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users       User[]
  permissions RolePermission[]
}

model RolePermission {
  id     String @id @default(uuid())
  roleId String
  menu   Menu

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, menu])
}

enum Menu {
  DASHBOARD
  MESAS
  PRODUCAO
  COZINHA
  BAR
  CAIXA
  PRODUTOS
  CATEGORIAS
  USUARIOS
  PERFIS
  CONFIG_MESAS
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  roleId    String? // ✅ opcional por enquanto
  createdAt DateTime @default(now())
  active    Boolean  @default(true) // ✅ NOVO

  role       Role?       @relation(fields: [roleId], references: [id]) // ✅ EXPLÍCITO
  orders     Order[]
  cancelLogs CancelLog[]
}

model Table {
  id        String      @id @default(uuid())
  number    Int         @unique
  status    TableStatus
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())

  comandas Comanda[]
}

enum TableStatus {
  LIVRE
  OCUPADA
}

model Product {
  id          String             @id @default(uuid())
  name        String
  price       Float
  available   Boolean            @default(true)
  destination ProductDestination @default(COZINHA)

  // ✅ TEMPORARIAMENTE OPCIONAL
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model Comanda {
  id        String   @id @default(uuid())
  tableId   String
  open      Boolean  @default(true)
  createdAt DateTime @default(now())

  table    Table        @relation(fields: [tableId], references: [id])
  orders   Order[]
  payments Payment[]
  pessoas  MesaPessoa[] // ✅ NOVO
}

model Order {
  id        String      @id @default(uuid())
  comandaId String
  userId    String
  number    Int         @default(0)
  status    OrderStatus @default(ENVIADO)
  createdAt DateTime    @default(now())

  comanda Comanda     @relation(fields: [comandaId], references: [id])
  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
}

model MesaPessoa {
  id        String   @id @default(uuid())
  name      String
  comandaId String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  comanda Comanda     @relation(fields: [comandaId], references: [id])
  itens   OrderItem[]
}

model OrderItem {
  id        String     @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  note      String?
  price     Float
  status    ItemStatus @default(PENDENTE)
  createdAt DateTime   @default(now())

  pessoaMesaId String?
  pessoaMesa   MesaPessoa? @relation(fields: [pessoaMesaId], references: [id])

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  cancelLogs CancelLog[] // ✅ ESTA LINHA
}

model Payment {
  id        String        @id @default(uuid())
  comandaId String
  method    PaymentMethod
  amount    Float
  createdAt DateTime      @default(now())

  comanda Comanda @relation(fields: [comandaId], references: [id])
}

enum ProductDestination {
  COZINHA
  BAR
  IMEDIATO
}

enum ItemStatus {
  PENDENTE
  EM_PREPARO
  PRONTO
  ENTREGUE
  CANCELADO   // ✅ NOVO
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  // ✅ RELAÇÃO OPOSTA (OBRIGATÓRIA NO PRISMA)
  products Product[]
}

model CancelLog {
  id          String   @id @default(uuid())
  userId      String
  orderItemId String
  reason      String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
}
