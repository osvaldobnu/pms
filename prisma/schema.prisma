generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // ⚠️ Se estiver no Prisma 6 (recomendado agora)
  url = env("DATABASE_URL")
}

enum Role {
  GARCOM
  COZINHA
  BAR
  CAIXA
  GERENTE
}

enum OrderStatus {
  ENVIADO
  EM_PREPARO
  PRONTO
}

enum PaymentMethod {
  DINHEIRO
  CARTAO
  PIX
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  orders    Order[]
  cancels   CancelLog[]
}

model Table {
  id        String   @id @default(uuid())
  number    Int      @unique
  status    TableStatus
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  comandas  Comanda[]
}

enum TableStatus {
  LIVRE
  OCUPADA
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  available   Boolean  @default(true)
  destination ProductDestination @default(COZINHA)

  // ✅ TEMPORARIAMENTE OPCIONAL
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
  items       OrderItem[]
}

model Comanda {
  id        String    @id @default(uuid())
  tableId   String
  open      Boolean   @default(true)
  createdAt DateTime  @default(now())

  table     Table     @relation(fields: [tableId], references: [id])
  orders    Order[]
  payments  Payment[]
}

model Order {
  id         String      @id @default(uuid())
  comandaId  String
  userId     String
  number     Int         @default(0)
  status     OrderStatus @default(ENVIADO)
  createdAt  DateTime    @default(now())

  comanda    Comanda     @relation(fields: [comandaId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id        String     @id @default(uuid())
  orderId  String
  productId String
  quantity Int
  note      String?
  price     Float
  status    ItemStatus @default(PENDENTE) // ✅ AQUI
  createdAt DateTime   @default(now())

  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Payment {
  id        String        @id @default(uuid())
  comandaId String
  method    PaymentMethod
  amount    Float
  createdAt DateTime      @default(now())

  comanda   Comanda       @relation(fields: [comandaId], references: [id])
}

model CancelLog {
  id        String   @id @default(uuid())
  userId    String
  reason    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

enum ProductDestination {
  COZINHA
  BAR
  IMEDIATO
}

enum ItemStatus {
  PENDENTE
  EM_PREPARO
  PRONTO
  ENTREGUE
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  // ✅ RELAÇÃO OPOSTA (OBRIGATÓRIA NO PRISMA)
  products  Product[]
}